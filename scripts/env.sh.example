# Keycloak connection
export KEYCLOAK_URL=https://keycloak-spiffe-demo.apps.example.com
export REALM=spiffe-demo

# First-hop client (agent-service)
export AGENT_CLIENT_ID=agent-service
export AGENT_CLIENT_SECRET=changeme

# Second-hop client (document-service)
export DOC_CLIENT_ID=document-service
export DOC_CLIENT_SECRET=changeme

# Test user (avoid USERNAME -- it's reserved on macOS)
export KC_USERNAME=alice
export KC_PASSWORD=alice123
